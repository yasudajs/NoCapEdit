{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "./src/dist",
    "distDir": "./src/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "NoCapEdit",
    "version": "0.2.13"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.nocapedit.dev",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "wix": {
          "language": "ja-JP",
          "fragmentPaths": ["wix/file-association.wxs"],
          "componentRefs": ["FileAssociationComponent"]
        },
        "nsis": {
          "template": "nsis/installer.nsi"
        }
      }
    },
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "save": true,
        "open": true,
        "ask": true,
        "message": true
      },
      "window": {
        "setTitle": true,
        "show": true
      }
    },
    "windows": [],
    "security": {
      "csp": null
    }
  }
}
