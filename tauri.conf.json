{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "./src/dist",
    "distDir": "./src/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "NoCapEdit",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "identifier": "com.nocapedit.dev",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "save": true,
        "open": true
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "NoCapEdit",
        "width": 900,
        "minHeight": 300,
        "minWidth": 400
      }
    ],
    "security": {
      "csp": null
    }
  }
}
